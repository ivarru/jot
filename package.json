{
  "name": "jot",
  "version": "0.19.8",
  "description": "A static progressive web app for personal Daily Notes.",
  "private": true,
  "license": "MIT",
  "author": "Ivar Rummelhoff",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivarru/jot.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "build:pages": "export BASE_PATH=${BASE_PATH:-/jot/}; npm run build && node scripts/prepare-pages.mjs",
    "verify:pages": "npm run test && npm run typecheck && npm run build:pages && npm run smoke:pages",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --outDir .output/public",
    "preview:test:fake": "node scripts/preview-test-fake-auth.mjs",
    "preview:test:oauth": "node scripts/preview-test-local-oauth.mjs",
    "smoke:pages": "node scripts/smoke-pages.mjs",
    "smoke:preview": "node scripts/smoke-preview.mjs",
    "smoke:raw-keyboard": "node scripts/smoke-raw-keyboard.mjs",
    "smoke:wysiwyg-paste": "node scripts/smoke-wysiwyg-paste.mjs",
    "smoke:link-modal": "node scripts/smoke-link-modal.mjs",
    "smoke:fake-daily-note-upload": "node scripts/smoke-fake-daily-note-upload.mjs",
    "smoke:fake-reconnect-conflict": "node scripts/smoke-fake-reconnect-conflict.mjs",
    "smoke:fake-image": "node scripts/smoke-fake-image.mjs",
    "smoke:fake-code-block-layout": "playwright test tests/smoke/code-block-layout.spec.ts",
    "smoke:toolbar-indent": "playwright test tests/smoke/toolbar-indent.spec.ts",
    "start": "vinxi start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@milkdown/kit": "^7.21.2",
    "@milkdown/plugin-automd": "7.21.2",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.3",
    "@solidjs/start": "^1.1.0",
    "diff": "^8.0.4",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "solid-js": "^1.9.9",
    "ulid": "^3.0.1",
    "vinxi": "^0.5.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdast": "^4.0.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "h3": "1.15.11"
  }
}
